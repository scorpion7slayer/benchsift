{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "benchsift",
    "compatibility_date": "2025-09-27",
    "compatibility_flags": ["nodejs_compat"],
    // Custom worker entry: TanStack Start fetch handler + a `scheduled` cron handler.
    "main": "src/server.ts",
    // Smart Placement: Cloudflare automatically places the Worker close to the
    // upstreams we hit most (artificialanalysis.ai, openrouter.ai,
    // huggingface.co) instead of running it at the edge nearest the user. The
    // cron pipeline is upstream-I/O-heavy, so this cuts wall-time noticeably.
    // Takes ~15 min after deploy to start optimising.
    "placement": {
        "mode": "smart",
    },
    "triggers": {
        // Pre-warm the KV cache so user requests don't trigger the AA scrape.
        "crons": ["*/30 * * * *"],
    },
    "workers_dev": false,
    "preview_urls": false,
    "observability": {
        "enabled": true,
    },
    "kv_namespaces": [
        {
            "binding": "MODELS_KV",
            "id": "2f526a06d8a349d49c446cd70b6e3786",
        },
    ],
}
